# Copy to .env and fill in. Never commit the real .env.
#
# Google API key — required for search_gcp_docs AND search_iam_docs.
# Enable BOTH "Developer Knowledge API" and "Custom Search API" in the
# same Google Cloud project, then create an API key restricted to those
# two APIs. Reused by both tools.
GOOGLE_DEVKNOWLEDGE_API_KEY=

# Programmable Search Engine ID (cx) — required for search_iam_docs.
# Create a PSE at programmablesearchengine.google.com scoped to the IAM
# doc sites listed in IAM_DOCS_DOMAINS in server.py, then paste the
# Search Engine ID here. Not secret.
GOOGLE_PSE_CX=

# GitHub PAT — optional for search_github_repos (raises rate limit to
# 5000/hr), required for search_github_code. Use a fine-grained token
# with only public-repo read access.
GITHUB_TOKEN=

# Optional: override defaults from server.py
# ARXIV_DOWNLOAD_DIR=~/arxiv-papers
# ARXIV_DB_PATH=~/arxiv-papers/arxiv_index.db
# UNPAYWALL_EMAIL=you@example.com
# CORE_API_KEY=
